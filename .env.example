# T-Invest API (только read-only токен, фаза 1)
TINVEST_READONLY_TOKEN=your_readonly_token_here
# TINVEST_FULL_ACCESS_TOKEN=  # ЗАПРЕЩЕНО в фазе 1

# Telegram (несколько получателей через запятую или точку с запятой)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_IDS=123456789,987654321

# SQLite (файл tradebot.db в корне проекта, Docker не нужен)
DATABASE_URL=sqlite+aiosqlite:///./tradebot.db

# AI (опционально, бот работает без него)
NVIDIA_AI_API_KEY=your_nvidia_ai_api_key_here
NVIDIA_AI_API_URL=https://integrate.api.nvidia.com/v1

# Настройки бота
SCAN_INTERVAL_SECONDS=60
LOG_LEVEL=INFO
ENVIRONMENT=development
